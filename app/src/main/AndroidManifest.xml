<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 1. PERMISOS DE RED (RA2: Consumo de servicios) -->
    <!-- Necesario para Firebase, la API de Deezer y Google Maps -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 2. PERMISOS DE UBICACIÓN (RA3: Localización) -->
    <!-- FINE_LOCATION para el GPS preciso y COARSE para ubicación por antenas/WiFi -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 3. PERMISOS DE ALMACENAMIENTO Y MULTIMEDIA (RA3: Multimedia) -->
    <!-- maxSdkVersion 32 asegura compatibilidad con versiones antiguas,
         mientras que READ_MEDIA_IMAGES es para Android 13 en adelante -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- 4. PERMISO DE NOTIFICACIONES (RA3: Avisos) -->
    <!-- Obligatorio para mostrar el aviso de proximidad en Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Consultas para interactuar con los Servicios de Google Play -->
    <queries>
        <package android:name="com.google.android.gms" />
    </queries>

    <application
        android:name=".SoundConnectApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Firebase"
        android:localeConfig="@xml/locales_config">

        <!-- 5. LLAVE DE GOOGLE MAPS -->
        <!-- Sin esto, el mapa saldría vacío o daría error de autenticación -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDA7CXH9D6jZnhYCCCwkbDM94oCJ1Hgzzs" />

        <!-- 6. ACTIVIDAD PRINCIPAL -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Firebase"
            android:windowSoftInputMode="adjustResize">

            <!-- El Intent Filter indica que esta es la pantalla de inicio (LAUNCHER) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
